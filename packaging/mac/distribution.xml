<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>SUB ORBIT</title>
    <welcome file="welcome.html"/>
    <license file="license.html"/>
    <options customize="allow" require-scripts="false" rootVolumeOnly="true"/>
    <choices-outline>
        <line choice="vst3"/>
        <line choice="au"/>
    </choices-outline>
    <choice id="vst3" title="VST3 Plugin" description="Install SUB ORBIT VST3 to /Library/Audio/Plug-Ins/VST3">
        <pkg-ref id="com.echoeslab.suborbit.vst3"/>
    </choice>
    <choice id="au" title="Audio Unit Plugin" description="Install SUB ORBIT AU to /Library/Audio/Plug-Ins/Components">
        <pkg-ref id="com.echoeslab.suborbit.au"/>
    </choice>
    <pkg-ref id="com.echoeslab.suborbit.vst3">SubOrbit-VST3.pkg</pkg-ref>
    <pkg-ref id="com.echoeslab.suborbit.au">SubOrbit-AU.pkg</pkg-ref>
</installer-gui-script>
